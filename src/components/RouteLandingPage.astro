---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from './Breadcrumbs.astro';
import type { RouteLandingItem } from '../site-config';
import { siteConfig } from '../site-config';
import { buildBreadcrumbJsonLd } from '../lib/seo-schema';

interface Props {
	landing: RouteLandingItem;
}

const { landing } = Astro.props;
const title = `${landing.title} | ${siteConfig.businessName}`;
const description = landing.description;
const keywords = landing.keywords;

const crumbs = [
	{ name: 'Home', path: '/' },
	{ name: 'Routes', path: '/#routes' },
	{ name: landing.title, path: landing.path },
];

const jsonLd = [
	buildBreadcrumbJsonLd(crumbs),
	{
		'@context': 'https://schema.org',
		'@type': 'Service',
		name: landing.title,
		description: landing.description,
		serviceType: 'Taxi and cab booking',
		provider: {
			'@type': 'TaxiService',
			name: siteConfig.businessName,
			telephone: siteConfig.phoneDisplay,
			url: siteConfig.siteUrl.replace(/\/$/, ''),
		},
		areaServed: siteConfig.serviceAreas.map((n) => ({ '@type': 'City', name: n })),
	},
	{
		'@context': 'https://schema.org',
		'@type': 'FAQPage',
		mainEntity: landing.faq.map((item) => ({
			'@type': 'Question',
			name: item.question,
			acceptedAnswer: {
				'@type': 'Answer',
				text: item.answer,
			},
		})),
	},
];
---

<BaseLayout title={title} description={description} keywords={keywords} path={landing.path} jsonLd={jsonLd}>
	<Breadcrumbs items={crumbs} />
	<section class="section container">
		<h1>{landing.h1}</h1>
		<p class="lead muted">{landing.lead}</p>
		<div class="hero-cta">
			<a class="btn btn-primary" href={`tel:${siteConfig.phoneHref}`}>Call {siteConfig.phoneDisplay}</a>
			<a class="btn btn-whatsapp" href={`https://wa.me/${siteConfig.whatsappNumber}`}>WhatsApp</a>
			<a class="btn btn-secondary" href="/contact/">Book now</a>
		</div>
	</section>

	<section class="section container">
		<h2>Why book this route with us</h2>
		<div class="grid cards-3">
			{
				landing.highlights.map((block) => (
					<article class="card">
						<h3>{block.title}</h3>
						<p class="muted">{block.body}</p>
					</article>
				))
			}
		</div>
	</section>

	<section class="section container">
		<h2>Related pages</h2>
		<p class="muted">Explore more services and fleet options.</p>
		<ul class="internal-links">
			{
				landing.relatedLinks.map((link) => (
					<li>
						<a href={link.href}>{link.label}</a>
					</li>
				))
			}
		</ul>
	</section>

	<section class="section container">
		<h2>Frequently asked questions</h2>
		<div class="grid">
			{
				landing.faq.map((item) => (
					<article class="card">
						<h3>{item.question}</h3>
						<p>{item.answer}</p>
					</article>
				))
			}
		</div>
	</section>
</BaseLayout>
