---
const currentPath = Astro.url.pathname;
const base = currentPath === '/' ? '' : '/';
const tabs = [
	{ id: 'home', label: 'Home', glyph: 'H' },
	{ id: 'packages', label: 'Packages', glyph: 'P' },
	{ id: 'routes', label: 'Routes', glyph: 'R' },
	{ id: 'fleet', label: 'Fleet', glyph: 'F' },
	{ id: 'enquiry', label: 'Enquiry', glyph: 'E' },
	{ id: 'contact', label: 'Contact', glyph: 'C' },
];
---

<nav class="mobile-tabbar" aria-label="Bottom navigation">
	{
		tabs.map((tab) => (
			<a class="tab-link section-link" data-section={tab.id} href={`${base}#${tab.id}`}>
				<span class="tab-icon" aria-hidden="true">{tab.glyph}</span>
				<span class="tab-label">{tab.label}</span>
			</a>
		))
	}
</nav>
