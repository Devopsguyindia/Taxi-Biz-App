---
import { siteConfig } from '../site-config';
const formEndpoint = siteConfig.formEndpoint;
---

<form class="card" id="enquiryForm" data-endpoint={formEndpoint}>
	<h2>Quick Enquiry</h2>
	<p class="muted">We will contact you shortly with fare details.</p>
	<p>
		<label for="name">Name</label><br />
		<input id="name" name="name" type="text" required />
	</p>
	<p>
		<label for="phone">Phone</label><br />
		<input id="phone" name="phone" type="tel" required />
	</p>
	<p>
		<label for="pickup">Pickup</label><br />
		<input id="pickup" name="pickup" type="text" required />
	</p>
	<p>
		<label for="drop">Drop</label><br />
		<input id="drop" name="drop" type="text" required />
	</p>
	<p>
		<label for="datetime">Date and Time</label><br />
		<input id="datetime" name="datetime" type="datetime-local" />
	</p>
	<p>
		<label for="packageType">Package</label><br />
		<select id="packageType" name="packageType">
			<option>Airport Pickup / Drop</option>
			<option>Local Hire</option>
			<option>Mumbai Return Package</option>
		</select>
	</p>
	<p>
		<label for="vehicle">Vehicle Preference</label><br />
		<select id="vehicle" name="vehicle">
			<option>Toyota Innova - SUV</option>
			<option>Maruti Ertiga - MUV</option>
			<option>Swift Dzire - Sedan</option>
		</select>
	</p>
	<p>
		<label for="message">Message</label><br />
		<textarea id="message" name="message" rows={4}></textarea>
	</p>
	<button class="btn btn-primary" type="submit">Send enquiry</button>
	<p id="formMessage" class="muted" style="margin-top: 10px;"></p>
</form>

<script>
	const form = document.getElementById('enquiryForm') as HTMLFormElement;
	const formMessage = document.getElementById('formMessage') as HTMLParagraphElement;
	const endpoint = form?.dataset.endpoint;

	if (!form || !formMessage || !endpoint) {
		console.error('Form elements not found');
	}

	form?.addEventListener('submit', async (e) => {
		e.preventDefault();
		
		const nameInput = form.querySelector('#name') as HTMLInputElement;
		const phoneInput = form.querySelector('#phone') as HTMLInputElement;
		const pickupInput = form.querySelector('#pickup') as HTMLInputElement;
		const dropInput = form.querySelector('#drop') as HTMLInputElement;
		const datetimeInput = form.querySelector('#datetime') as HTMLInputElement;
		const packageTypeInput = form.querySelector('#packageType') as HTMLSelectElement;
		const vehicleInput = form.querySelector('#vehicle') as HTMLSelectElement;
		const messageInput = form.querySelector('#message') as HTMLTextAreaElement;
		const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;

		if (!nameInput || !phoneInput || !pickupInput || !dropInput || !submitBtn) {
			console.error('Form inputs not found');
			return;
		}

		const formData = {
			name: nameInput.value,
			phone: phoneInput.value,
			pickup: pickupInput.value,
			drop_location: dropInput.value,
			datetime: datetimeInput?.value || '',
			packageType: packageTypeInput?.value || 'Airport Pickup / Drop',
			vehicle: vehicleInput?.value || 'Toyota Innova - SUV',
			message: messageInput?.value || ''
		};

		submitBtn.disabled = true;
		submitBtn.textContent = 'Sending...';

		try {
			const response = await fetch(endpoint!, {
				method: 'POST',
				headers: {
					'Content-Type': 'application/json',
				},
				body: JSON.stringify(formData)
			});

			const data = await response.json();

			if (response.ok && data.success) {
				formMessage.textContent = 'Thank you! Your enquiry has been submitted successfully.';
				formMessage.style.color = 'green';
				form.reset();
			} else {
				formMessage.textContent = data.message || 'Failed to submit enquiry. Please try again.';
				formMessage.style.color = 'red';
			}
		} catch (error) {
			formMessage.textContent = 'Error submitting form. Please try again.';
			formMessage.style.color = 'red';
		} finally {
			submitBtn.disabled = false;
			submitBtn.textContent = 'Send enquiry';
		}
	});
</script>
