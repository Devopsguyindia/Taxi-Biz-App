---
import { siteConfig } from '../site-config';
---

<footer class="site-footer">
	<div class="container grid footer-grid">
		<section>
			<h2>{siteConfig.businessName}</h2>
			<p class="muted">
				Trusted cab service for airport transfers, local rides, and Mumbai return trips.
			</p>
		</section>
		<section>
			<h2>Contact</h2>
			<p>
				<a href={`tel:${siteConfig.phoneHref}`}>{siteConfig.phoneDisplay}</a>
			</p>
			<p>
				<a href={`https://wa.me/${siteConfig.whatsappNumber}`}>WhatsApp chat</a>
			</p>
		</section>
		<section>
			<h2>Service Areas</h2>
			<p>{siteConfig.serviceAreas.join(', ')}</p>
		</section>
		<section>
			<h2>Popular routes</h2>
			<ul class="footer-links">
				<li><a href="/routes/pune-to-mumbai-taxi/">Pune to Mumbai taxi</a></li>
				<li><a href="/routes/mumbai-airport-drop/">Mumbai airport drop</a></li>
				<li><a href="/routes/pune-airport-taxi/">Pune airport taxi</a></li>
				<li><a href="/routes/new-mumbai-pune-taxi/">New Mumbai ↔ Pune</a></li>
			</ul>
		</section>
	</div>
</footer>
