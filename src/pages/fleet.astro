---
import Breadcrumbs from '../components/Breadcrumbs.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import VehicleCard from '../components/VehicleCard.astro';
import { buildBreadcrumbJsonLd } from '../lib/seo-schema';
import { siteConfig } from '../site-config';

const seoPage = siteConfig.seo.pages.fleet;
const title = `${seoPage.title} | ${siteConfig.businessName}`;
const description = seoPage.description;
const keywords = seoPage.keywords;

const crumbs = [
	{ name: 'Home', path: '/' },
	{ name: seoPage.title, path: seoPage.path },
];

const jsonLd = [
	buildBreadcrumbJsonLd(crumbs),
	{
		'@context': 'https://schema.org',
		'@type': 'ItemList',
		name: 'Taxi Fleet',
		itemListElement: siteConfig.fleet.map((vehicle, index) => ({
			'@type': 'ListItem',
			position: index + 1,
			name: `${vehicle.name} - ${vehicle.type}`,
		})),
	},
];
---

<BaseLayout title={title} description={description} keywords={keywords} path={seoPage.path} jsonLd={jsonLd}>
	<Breadcrumbs items={crumbs} />
	<section class="section container">
		<h1>Our Vehicles</h1>
		<p class="muted">Well-maintained options for solo travelers, families, and corporate bookings.</p>
		<div class="grid cards-3">
			{
				siteConfig.fleet.map((vehicle) => (
					<VehicleCard
						name={vehicle.name}
						type={vehicle.type}
						passengerInfo={vehicle.passengerInfo}
						icon={vehicle.icon}
						imageUrl={vehicle.imageUrl}
						imageAlt={vehicle.imageAlt}
					/>
				))
			}
		</div>
		<p class="muted">
			Booking a route? Start with
			<a href="/routes/pune-to-mumbai-taxi/">Pune–Mumbai taxi</a>,
			<a href="/routes/pune-airport-taxi/">Pune airport taxi</a>, or
			<a href="/contact/">contact us</a>.
		</p>
	</section>
</BaseLayout>
