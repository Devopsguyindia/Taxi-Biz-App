---
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { buildBreadcrumbJsonLd } from '../../lib/seo-schema';
import { siteConfig } from '../../site-config';

const seoPage = siteConfig.seo.pages.localHire;
const title = `${seoPage.title} | ${siteConfig.businessName}`;
const description = seoPage.description;
const keywords = seoPage.keywords;

const crumbs = [
	{ name: 'Home', path: '/' },
	{ name: seoPage.title, path: seoPage.path },
];

const jsonLd = [
	buildBreadcrumbJsonLd(crumbs),
	{
		'@context': 'https://schema.org',
		'@type': 'Service',
		serviceType: 'Local taxi hire',
		provider: {
			'@type': 'TaxiService',
			name: siteConfig.businessName,
		},
		areaServed: ['Pune'],
	},
];
---

<BaseLayout title={title} description={description} keywords={keywords} path={seoPage.path} jsonLd={jsonLd}>
	<Breadcrumbs items={crumbs} />
	<section class="section container">
		<h1>Local Hire Package</h1>
		<p class="muted">
			Local hire is ideal for city meetings, shopping routes, and personal travel with flexible stops.
		</p>
		<div class="grid cards-3">
			<article class="card">
				<h2>Flexible start point</h2>
				<p>Choose pickup from home, hotel, office, or airport.</p>
			</article>
			<article class="card">
				<h2>Driver with route support</h2>
				<p>Experienced local drivers help optimize city travel time.</p>
			</article>
			<article class="card">
				<h2>Vehicle options</h2>
				<p>Innova, Ertiga, and Swift Dzire available based on comfort and budget.</p>
			</article>
		</div>
		<p class="muted">
			Also see <a href="/fleet/">fleet & vehicle types</a> and
			<a href="/routes/pune-to-mumbai-taxi/">Pune–Mumbai taxi</a> for intercity travel.
		</p>
		<p>
			<a class="btn btn-primary" href="/contact/">Get local hire quote</a>
		</p>
	</section>
</BaseLayout>
